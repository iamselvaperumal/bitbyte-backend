NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173

MONGO_URI=your_mongodb_connection_string
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=7d
JWT_COOKIE_EXPIRES_IN=7

SUPER_ADMIN_EMAIL=superadmin@company.com
SUPER_ADMIN_FIRST_NAME=Super
SUPER_ADMIN_LAST_NAME=Admin
SUPER_ADMIN_PASSWORD=change_this_password

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
EMAIL_FROM=hr@example.com
EMAIL_FROM_NAME=HR Portal
COMPANY_NAME=Your Company

GOOGLE_ATTENDANCE_SPREADSHEET_ID=your_spreadsheet_id
GOOGLE_ATTENDANCE_SHEET_NAME=Attendance
